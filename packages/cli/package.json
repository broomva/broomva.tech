{
  "name": "@broomva/cli",
  "version": "0.1.0",
  "description": "CLI for broomva.tech — prompts, skills, and context from the terminal",
  "type": "module",
  "bin": {
    "broomva": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "broomva",
  "repository": {
    "type": "git",
    "url": "https://github.com/broomva/broomva.tech",
    "directory": "packages/cli"
  },
  "keywords": [
    "broomva",
    "cli",
    "prompts",
    "skills",
    "ai"
  ]
}
