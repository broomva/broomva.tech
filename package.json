{
  "name": "broomva-tech",
  "private": true,
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@chatjs/chat",
    "build": "turbo run build --filter=@chatjs/chat",
    "lint": "turbo run lint --filter=@chatjs/chat",
    "test": "turbo run test --filter=@chatjs/chat",
    "test:types": "turbo run test:types --filter=@chatjs/chat",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  }
}
